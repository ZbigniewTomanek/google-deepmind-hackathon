# LLM Provider (z.ai or any OpenAI-compatible)
ZAI_API_KEY=your-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# FastAPI
HOST=0.0.0.0
PORT=8003

# OpenCode web server
OPENCODE_PORT=4098

# NeoCortex MCP Server (the system under test)
NEOCORTEX_MCP_URL=http://localhost:8000
NEOCORTEX_AUTH_TOKEN=claude-code-work

# Docker-only (set these when using docker-compose)
# PROJECT_ROOT=/absolute/path/to/google-deepmind-hackathon
# OPENCODE_BIN=/path/to/.opencode/bin/opencode
# HOST_UID=1000
# HOST_GID=1000

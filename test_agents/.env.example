# LLM Provider (z.ai or any OpenAI-compatible)
ZAI_API_KEY=your-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# FastAPI
HOST=0.0.0.0
PORT=8003

# OpenCode web server
OPENCODE_PORT=4098

# NeoCortex MCP Server (the system under test)
NEOCORTEX_MCP_URL=http://localhost:8000
NEOCORTEX_AUTH_TOKEN=dev-token-neocortex
NEOCORTEX_CHAT_TOKEN=chat-agent-token
NEOCORTEX_JOKE_TOKEN=joke-agent-token
NEOCORTEX_RESEARCH_ORCH_TOKEN=research-orch-token
NEOCORTEX_VIDEO_PROC_TOKEN=video-processor-token
NEOCORTEX_AUDIO_PROC_TOKEN=audio-processor-token
NEOCORTEX_RSS_PROC_TOKEN=rss-processor-token
NEOCORTEX_CHAT_EXTRACTIONS_TOKEN=chat-extractions-token

# Docker-only (set these when using docker-compose)
# PROJECT_ROOT=/absolute/path/to/google-deepmind-hackathon
# OPENCODE_BIN=/path/to/.opencode/bin/opencode
# HOST_UID=1000
# HOST_GID=1000
